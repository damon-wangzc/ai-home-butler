# ── Model server ──────────────────────────────────────────
# llama.cpp C++ server is used in ALL environments — only these values change.
#
# WSL (RTX A3000 12 GB):  N_GPU_LAYERS=99  KV_CACHE_TYPE=f16   MODEL_CTX_SIZE=8192
# DELL (P1000 4 GB):       N_GPU_LAYERS=99  KV_CACHE_TYPE=q4_0  MODEL_CTX_SIZE=81920
# CPU-only fallback:       N_GPU_LAYERS=0   (remove devices: blocks in compose.yml)
N_GPU_LAYERS=99
MODEL_FILE=Qwen3.5-2B-Q4_K_M.gguf
MODEL_NAME=local
MODEL_CTX_SIZE=4096

# KV cache quantisation — controls VRAM used by the attention cache.
# f16  = default, full precision (~450 MB at 4K ctx / ~6 GB at 80K ctx)
# q8_0 = halves KV memory, negligible quality loss
# q4_0 = quarters KV memory — required on P1000 for ctx ≥ 16K
# DELL P1000 + 80K context → KV_CACHE_TYPE=q4_0
KV_CACHE_TYPE=f16

# ── Orchestrator ──────────────────────────────────────────
MAX_TOKENS=1024
TEMPERATURE=0.2

# ── Phase 1: Memory & Tools ──────────────────────────────
# Alpha Vantage free key (25 req/day): https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=
PRICE_CACHE_TTL=300

# Cost tracking rates (credits per 1M tokens, GPT-5 mini defaults)
IN_RATE_PER_1M=25.0
OUT_RATE_PER_1M=200.0

# ── Phase 3: Audio ────────────────────────────────────────
# STT (Faster-Whisper): model sizes: tiny, base, small, medium
# DELL P1000: set WHISPER_DEVICE=cuda + WHISPER_COMPUTE=float16 (~250 MB VRAM, ~8× faster)
# CPU-only:   set WHISPER_DEVICE=cpu  + WHISPER_COMPUTE=int8
WHISPER_MODEL=tiny
WHISPER_DEVICE=cpu
WHISPER_COMPUTE=int8
# TTS (Piper): see tts/main.py _VOICE_BASE_URLS for available voices
# Available voices (files must exist in data/tts-voices/):
#   en_US-lessac-medium  (English US, Lessac — default)
#   en_US-amy-medium     (English US, Amy)
#   sv_SE-nst-medium     (Swedish)
#   zh_CN-xiao_ya-medium (Chinese Simplified)
VOICE_NAME=en_US-lessac-medium

# ── Phase 4: Smart Home / RAG ────────────────────────────
# MQTT broker (mosquitto container — auto-configured in compose.yml)
# Override only if running a separate MQTT broker:
# MQTT_HOST=mosquitto
# MQTT_PORT=1883

# Home Assistant REST API integration
# Get a Long-Lived Access Token from: HA → Profile → Long-Lived Access Tokens
# Tip: use the LAN IP directly (e.g. 192.168.1.98) instead of homeassistant.local —
#      containers can't resolve mDNS .local names.
# HA_URL=http://192.168.1.98:8123
# HA_TOKEN=your_long_lived_access_token_here

# RAG / Home Knowledge (drop .txt or .md files into data/home-docs/)
RAG_TOP_K=3
CHUNK_SIZE=400

# ── MCP Servers ───────────────────────────────────────────
# Comma-separated list of MCP SSE base-URLs.
# The orchestrator discovers tools from each server at startup.
# fetch-mcp is always included (runs as a container in the stack).
# To add Home Assistant MCP:
#   1. Enable "MCP Server" integration in HA (Settings → Integrations → Add → Model Context Protocol)
#   2. Create a Long-Lived Access Token (HA → Profile → Long-Lived Access Tokens)
#   3. Uncomment and fill in the two lines below
#
# MCP_SERVERS=http://fetch-mcp:8400,http://192.168.1.98:8123/mcp_server
# MCP_TOKENS=,<your-long-lived-access-token>
#             ^ empty first token = no auth for fetch-mcp; second token = HA Bearer token
MCP_SERVERS=http://fetch-mcp:8400
MCP_TOKENS=

# ── Phase 6: Robotics / Vision ───────────────────────────
# Frigate NVR REST API (requires camera hardware)
# FRIGATE_URL=http://frigate:5000
